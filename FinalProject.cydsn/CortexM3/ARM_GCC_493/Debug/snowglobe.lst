  45:.\snowglobe.c **** static int16_t randPM(int16_t range)
  46:.\snowglobe.c **** {
  47:.\snowglobe.c ****     if (range <= 0) return 0;
  48:.\snowglobe.c ****     return (int16_t)((rand() % (2 * range + 1)) - range);
  49:.\snowglobe.c **** }
