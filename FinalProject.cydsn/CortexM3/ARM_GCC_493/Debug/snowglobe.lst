   1:.\snowglobe.c **** #include <project.h>
   2:.\snowglobe.c **** #include <stdlib.h>
   3:.\snowglobe.c **** #include "tft.h"
   4:.\snowglobe.c **** #include "snowglobe.h"
   5:.\snowglobe.c **** 
   6:.\snowglobe.c **** #define PARTICLES_PER_SCREEN  20
   7:.\snowglobe.c **** #define PARTICLE_PX           5                     // particle is PARTICLE_PX * PARTICLE_PX pixels
   8:.\snowglobe.c **** 
   9:.\snowglobe.c **** // fixed point in Q4
  10:.\snowglobe.c **** #define Q                     4
  11:.\snowglobe.c **** #define ONE_PX                (1 << Q)
  12:.\snowglobe.c **** 
  13:.\snowglobe.c **** // physics
  14:.\snowglobe.c **** #define MAX_SPEED             (8 * ONE_PX)          // terminal speed in either axis
  15:.\snowglobe.c **** #define DAMP_NUM              15                    // velocity *= 15/16 each tick as drag
  16:.\snowglobe.c **** #define DAMP_DEN              16
  17:.\snowglobe.c **** #define SHAKE_KICK            (20 * ONE_PX)         // shake gives random vel in +/- SHAKE_KICK
  18:.\snowglobe.c **** #define WALL_BOUNCE_NUM       1                     // bounce keeps 1/2 of speed into wall
  19:.\snowglobe.c **** #define WALL_BOUNCE_DEN       2
  20:.\snowglobe.c **** #define SHAKE_THRESHOLD       2000                  // threshold for difference from 1g for applyin
  21:.\snowglobe.c **** #define GRAVITY_SHIFT         13                    // by default for the IMU, 1g = 2^13 --> divide
  22:.\snowglobe.c **** 
  23:.\snowglobe.c **** #define BG_COLOR              0x0000   // black
  24:.\snowglobe.c **** #define SNOW_COLOR            0xFFFF   // white
  25:.\snowglobe.c **** 
  26:.\snowglobe.c **** 
  27:.\snowglobe.c **** // vars to convert from accelerometer data (ax, ay, az) into a 2D gravity vector for each screen
  28:.\snowglobe.c **** static const uint8_t gx_use_ay[NUM_SCREENS] = { 0, 1, 0, 1 };
  29:.\snowglobe.c **** static const int8_t  gx_sign  [NUM_SCREENS] = {-1,-1,+1,+1 };           // gx is horizontal acceler
  30:.\snowglobe.c **** static const int8_t  gy_sign  [NUM_SCREENS] = {+1,+1,+1,+1 };           // gy is vertical accelerat
  31:.\snowglobe.c **** 
  32:.\snowglobe.c **** 
ARM GAS  C:\Users\ericz\AppData\Local\Temp\ccL1nUOV.s 			page 2


  33:.\snowglobe.c **** typedef struct {
  34:.\snowglobe.c ****     int16_t x, y;        // position in Q4 sub-pixels
  35:.\snowglobe.c ****     int16_t vx, vy;      // velocity in Q4 sub-pixels per tick
  36:.\snowglobe.c ****     int16_t prev_px;     // last drawn pixel position
  37:.\snowglobe.c ****     int16_t prev_py;
  38:.\snowglobe.c **** } Particle;
